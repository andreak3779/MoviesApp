@model MoviesWeb.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

<div class="container mt-5">
    <h1>@Model.Title</h1>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <p>
                <strong>Director:</strong> @Model.Director
            </p>
            <p>
                <strong>Release Date:</strong> @Model.ReleaseDate?.ToString("yyyy-MM-dd")
            </p>
            <p>
                <strong>Genre:</strong> @Model.Genre
            </p>
            <p>
                <strong>Description:</strong><br />
                @Model.Description
            </p>
           
        </div>
    </div>
    
    <div class="mt-4">
        <a href="@Url.Action("Index", "Movie")" class="btn btn-secondary">Back to List</a>
        <a href="@Url.Action("Edit", "Movie", new { id = Model.Id })" class="btn btn-primary">Edit</a>
    </div>
</div>