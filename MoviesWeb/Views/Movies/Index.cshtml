@{
    ViewData["Title"] = "Movies";
}

<h1>Movies</h1>

<div id="movies">Loading...</div>

<script>
async function loadMovies() {
    try {
        const res = await fetch('/movies');
        if (!res.ok) {
            document.getElementById('movies').innerText = 'Failed to load movies.';
            return;
        }
        const movies = await res.json();
        const container = document.getElementById('movies');
        if (!movies || movies.length === 0) {
            container.innerText = 'No movies found.';
            return;
        }
        const ul = document.createElement('ul');
        movies.forEach(m => {
            const li = document.createElement('li');
            const a = document.createElement('a');
            const id = m.id ?? m.Id ?? '';
            const title = m.title ?? m.Title ?? 'Untitled';
            const year = m.releaseYear ?? m.ReleaseYear ?? '';
            a.href = '/Movies/Details/' + id;
            a.innerText = `${title} ${year ? '(' + year + ')' : ''}`;
            li.appendChild(a);
            ul.appendChild(li);
        });
        container.innerHTML = '';
        container.appendChild(ul);
    } catch (err) {
        document.getElementById('movies').innerText = 'Error loading movies.';
        console.error(err);
    }
}

loadMovies();
</script>
